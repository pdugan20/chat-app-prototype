# Public, non-secret URL embedded in the Expo app
EXPO_PUBLIC_AI_PROXY_URL=http://127.0.0.1:8787

# Private values read only by the local Node process
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PROXY_PORT=8787

# Apple Music
EXPO_PUBLIC_APPLE_MUSIC_TOKEN=

# Apple Music token gereration
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_FILE=

# Cloudinary (for image proxy)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
