{
  "name": "imessage-prototype",
  "version": "1.0.8",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "generate-apple-token": "node scripts/generate-apple-music-token.js",
    "setup-hooks": "chmod +x scripts/setup-hooks.sh .githooks/pre-commit .githooks/pre-push && ./scripts/setup-hooks.sh",
    "sb": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start",
    "sb:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo run:ios",
    "sb:generate": "sb-rn-get-stories",
    "android": "expo run:android",
    "knip": "knip",
    "markdownlint": "markdownlint '**/*.md' --ignore node_modules --ignore CHANGELOG.md --ignore ios --ignore android",
    "markdownlint:fix": "markdownlint '**/*.md' --ignore node_modules --ignore CHANGELOG.md --ignore ios --ignore android --fix",
    "lint:claude": "claudelint check-all",
    "lint:claude:fix": "claudelint format --fix"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx}": [
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint --ignore node_modules --ignore CHANGELOG.md"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@expo/ui": "~55.0.17",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/native": "^7.1.16",
    "@react-navigation/native-stack": "^7.3.23",
    "expo": "~55.0.28",
    "expo-audio": "~55.0.16",
    "expo-blur": "~55.0.16",
    "expo-dev-client": "~55.0.37",
    "expo-image": "~55.0.11",
    "expo-linear-gradient": "~55.0.16",
    "expo-module-scripts": "^4.1.10",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.9",
    "openai": "^5.11.0",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@storybook/addon-actions": "^9.0.8",
    "@storybook/addon-ondevice-actions": "^9.1.4",
    "@storybook/addon-ondevice-controls": "^9.1.4",
    "@storybook/addon-ondevice-notes": "^9.1.4",
    "@storybook/react-native": "^9.1.4",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "babel-loader": "^8.4.1",
    "claude-code-lint": "^0.7.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.20",
    "jsonwebtoken": "^9.0.3",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli": "^0.49.1",
    "prettier": "^3.9.6",
    "react-dom": "19.2.8",
    "semantic-release": "^24.2.9",
    "storybook": "^9.1.20",
    "typescript": "~5.9.3"
  },
  "private": true,
  "overrides": {
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "postcss": "^8.5.10",
    "@xmldom/xmldom": "^0.8.13",
    "flatted": "^3.4.2",
    "glob": "^11.1.0",
    "handlebars": "^4.7.9",
    "jws": "^3.2.3",
    "lodash": "^4.18.0",
    "lodash-es": "^4.18.0",
    "minimatch": "^10.2.3",
    "picomatch": "^4.0.4",
    "tar": "^7.5.11",
    "brace-expansion": "^5.0.5",
    "ip-address": "^10.1.1",
    "js-yaml": "^4.1.1",
    "yaml": "^2.8.3",
    "test-exclude": {
      "glob": "^7.1.4",
      "minimatch": "^3.0.4"
    }
  }
}
